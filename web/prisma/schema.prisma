generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Certificate {
  id         String   @id @default(cuid())
  verifyCode String   @unique @default(cuid())
  name       String
  score      Int
  issuedAt   DateTime @default(now())
}

model ExamSession {
  id          String    @id @default(cuid())
  cookieId    String
  name        String
  startedAt   DateTime  @default(now())
  expiresAt   DateTime
  submittedAt DateTime?
  score       Int?
  passed      Boolean?
  verifyCode  String?

  @@index([cookieId])
}
